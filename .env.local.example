# ─── Stripe Payment Links ────────────────────────────────────────────────────
# Generate in Stripe Dashboard → Payment Links
NEXT_PUBLIC_STRIPE_STARTER=https://buy.stripe.com/YOUR_STARTER_LINK
NEXT_PUBLIC_STRIPE_PRO=https://buy.stripe.com/YOUR_PRO_LINK

# ─── Google Sheets ────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → create a project
# 2. Enable "Google Sheets API"
# 3. Create a Service Account → generate a JSON key
# 4. Copy the "client_email" and "private_key" values below
# 5. Share your Google Sheet with the service account email (Editor)
# 6. Copy the Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
# 7. Rename first sheet tab to "Leads"
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → follow steps → copy token
# 2. Start a conversation with your bot, then open:
#    https://api.telegram.org/bot{TOKEN}/getUpdates
#    Copy the "id" from "chat" object — that's your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here
