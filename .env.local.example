# ─── Stripe Payment Links ────────────────────────────────────────────────────
# Generate in Stripe Dashboard → Payment Links
NEXT_PUBLIC_STRIPE_STARTER=https://buy.stripe.com/YOUR_STARTER_LINK
NEXT_PUBLIC_STRIPE_PRO=https://buy.stripe.com/YOUR_PRO_LINK

# ─── Google Sheets (via Apps Script — no credentials needed) ─────────────────
# 1. Create a Google Sheet, rename tab to "Leads"
# 2. Add headers row: Date | Nom | Email | Téléphone | Projet | Budget | Délai | Objectif | Message | Langue
# 3. Extensions → Apps Script → paste the doPost script → Deploy → Web app
#    (Execute as: Me, Who has access: Anyone) → copy the Web app URL
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → follow steps → copy token
# 2. Start a conversation with your bot, then open:
#    https://api.telegram.org/bot{TOKEN}/getUpdates
#    Copy the "id" from "chat" object — that's your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here
